{
  "name": "@stacx/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply stacx-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply stacx-db --remote"
  },
  "dependencies": {
    "arctic": "^3.0.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
