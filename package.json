{
  "name": "stacx",
  "version": "1.0.0",
  "description": "StacX — 業務の学びを「1 分メモ」として蓄積し職務経歴書として再利用する個人向けアプリ（モノレポ）",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @stacx/api dev",
    "dev:web": "pnpm --filter @stacx/web dev",
    "build": "pnpm -r build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16"
  }
}
