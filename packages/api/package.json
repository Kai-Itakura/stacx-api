{
  "name": "@stacx/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply stacx-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply stacx-db --remote"
  },
  "dependencies": {
    "arctic": "^3.0.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.61",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^22.19.19",
    "@vitest/coverage-istanbul": "3.2.4",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.0.0"
  }
}
